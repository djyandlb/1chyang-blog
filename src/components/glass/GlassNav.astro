---
// src/components/glass/GlassNav.astro — 磨砂玻璃导航条
export interface NavItem {
  label: string;
  href: string;
}

export interface Props {
  items: NavItem[];
  brand?: string;
}

const { items, brand = '一步穿杨' } = Astro.props;
---

<nav
  class="glass sticky top-4 z-100 flex items-center justify-between px-7 py-3.5 mt-5 transition-all duration-300"
  style="backdrop-filter: blur(var(--glass-blur-lg)); -webkit-backdrop-filter: blur(var(--glass-blur-lg));"
>
  <a href="/" class="text-gradient text-xl font-bold tracking-wider no-underline">
    {brand}
  </a>
  <ul class="flex gap-7 list-none">
    {items.map((item) => (
      <li>
        <a
          href={item.href}
          class="text-[var(--text-secondary)] text-sm no-underline transition-colors duration-250 hover:text-[var(--gold-light)]"
          style="font-family: 'Microsoft YaHei', 'PingFang SC', sans-serif;"
        >
          {item.label}
        </a>
      </li>
    ))}
  </ul>
</nav>
