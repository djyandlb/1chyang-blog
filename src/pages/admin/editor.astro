---
// src/pages/admin/editor.astro — 文章编辑器
import AdminLayout from '../../layouts/AdminLayout.astro';
import GlassCard from '../../components/glass/GlassCard.astro';
import GlassInput from '../../components/glass/GlassInput.astro';
import GlassButton from '../../components/glass/GlassButton.astro';
import { getAllPostsAdmin } from '../../lib/posts';

export const prerender = false;

// 检查是否有 id 参数（编辑模式）
const url = new URL(Astro.request.url);
const editId = url.searchParams.get('id');

let post: { id?: string; title?: string; slug?: string; date?: string; tags?: string[]; excerpt?: string; content?: string; published?: boolean } | null = null;

if (editId) {
  const all = await getAllPostsAdmin();
  const found = all.find((p) => p.id === editId);
  if (found) {
    const { getPostBySlug } = await import('../../lib/posts');
    post = await getPostBySlug(found.slug);
  }
}
---

<AdminLayout>
  <h1
    class="text-2xl font-bold mb-8"
    style="font-family: 'Microsoft YaHei', 'PingFang SC', sans-serif; font-weight: 900;"
  >
    {post ? '编辑文章' : '新建文章'}
  </h1>

  <a href="/admin" class="inline-block mb-6 text-sm text-[var(--text-muted)] no-underline hover:text-[var(--gold-light)] transition-colors" style="font-family: 'Microsoft YaHei', 'PingFang SC', sans-serif;">
    ← 返回文章列表
  </a>

  <div class="grid gap-6" style="grid-template-columns: 1fr 1fr;">
    <!-- 编辑区 -->
    <div>
      <GlassCard padding="large">
        <form id="editor-form" class="flex flex-col gap-4">
          <GlassInput
            label="标题"
            name="title"
            type="text"
            required
            value={post?.title || ''}
            placeholder="文章标题"
          />
          <GlassInput
            label="Slug（URL 标识）"
            name="slug"
            type="text"
            required
            value={post?.slug || ''}
            placeholder="hello-world"
          />
          <div class="grid grid-cols-2 gap-4">
            <GlassInput
              label="日期"
              name="date"
              type="text"
              value={post?.date || new Date().toISOString().slice(0, 10)}
              placeholder="2026-07-05"
            />
            <GlassInput
              label="标签（逗号分隔）"
              name="tags"
              type="text"
              value={post?.tags?.join(', ') || ''}
              placeholder="前端, Astro, CSS"
            />
          </div>
          <GlassInput
            label="摘要"
            name="excerpt"
            type="text"
            value={post?.excerpt || ''}
            placeholder="一句话描述这篇文章…"
          />

          <GlassInput
            label="正文（Markdown）"
            name="content"
            type="textarea"
            value={post?.content || ''}
            placeholder="在这里写 Markdown…"
            class="min-h-[400px]"
          />

          <!-- 图片上传区 -->
          <div
            id="drop-zone"
            class="glass border-dashed border-[var(--gold)]/30 text-center py-8 cursor-pointer transition-colors hover:border-[var(--gold)]/60"
            style="border-radius: 14px;"
          >
            <p class="text-sm text-[var(--text-muted)]">
              📁 拖拽图片到此处上传
            </p>
            <input type="file" id="file-input" accept="image/*" class="hidden" />
          </div>

          <!-- 隐藏字段 -->
          <input type="hidden" name="id" value={post?.id || ''} />

          <div class="flex gap-3 mt-2">
            <GlassButton type="submit" variant="primary" size="md">
              💾 {post ? '更新文章' : '发布文章'}
            </GlassButton>
            <button
              type="button"
              id="save-draft-btn"
              class="glass px-5 py-2.5 rounded-[14px] text-sm cursor-pointer text-[var(--text-muted)] hover:text-[var(--text-primary)] transition-colors"
              style="backdrop-filter: blur(var(--glass-blur)); font-family: 'Microsoft YaHei', 'PingFang SC', sans-serif;"
            >
              保存草稿
            </button>
          </div>
        </form>
      </GlassCard>
    </div>

    <!-- 预览区 -->
    <div>
      <h3
        class="text-sm font-medium mb-3 text-[var(--text-muted)]"
        style="font-family: 'Microsoft YaHei', 'PingFang SC', sans-serif;"
      >
        实时预览
      </h3>
      <GlassCard padding="large">
        <div
          id="preview"
          class="prose prose-invert max-w-none
            prose-headings:font-black prose-headings:text-[var(--text-primary)]
            prose-p:text-[var(--text-secondary)] prose-p:leading-relaxed
            prose-a:text-[var(--gold)] prose-a:no-underline
            prose-code:bg-[var(--glass-bg)] prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded
            prose-pre:bg-[var(--glass-bg)] prose-pre:border prose-pre:border-[var(--glass-border)]
            prose-img:rounded-[var(--radius)]"
        >
          <p class="text-[var(--text-muted)]">在左侧输入 Markdown 内容…</p>
        </div>
      </GlassCard>
    </div>
  </div>

  <!-- 编辑器脚本 — 使用 npm 包中的 marked，不依赖 CDN -->
  <script>
    import { marked } from 'marked';

    const contentTextarea = document.querySelector('[name="content"]');
    const preview = document.getElementById('preview');

    // 实时预览
    if (contentTextarea && preview) {
      contentTextarea.addEventListener('input', () => {
        if (contentTextarea.value.trim()) {
          preview.innerHTML = marked.parse(contentTextarea.value);
        } else {
          preview.innerHTML = '<p class="text-[var(--text-muted)]">在左侧输入 Markdown 内容…</p>';
        }
      });

      if (contentTextarea.value.trim()) {
        preview.innerHTML = marked.parse(contentTextarea.value);
      }
    }

    // 图片拖拽上传
    const dropZone = document.getElementById('drop-zone');
    const fileInput = document.getElementById('file-input');

    if (dropZone && fileInput) {
      dropZone.addEventListener('click', () => fileInput.click());

      dropZone.addEventListener('dragover', (e) => {
        e.preventDefault();
        dropZone.classList.add('border-[var(--gold)]/60');
      });
      dropZone.addEventListener('dragleave', () => {
        dropZone.classList.remove('border-[var(--gold)]/60');
      });
      dropZone.addEventListener('drop', async (e) => {
        e.preventDefault();
        dropZone.classList.remove('border-[var(--gold)]/60');
        const file = e.dataTransfer?.files?.[0];
        if (file) await uploadAndInsert(file);
      });

      fileInput.addEventListener('change', async () => {
        const file = fileInput.files?.[0];
        if (file) await uploadAndInsert(file);
      });
    }

    async function uploadAndInsert(file) {
      const formData = new FormData();
      formData.append('file', file);
      try {
        const res = await fetch('/api/upload', { method: 'POST', body: formData });
        const data = await res.json();
        if (data.url && contentTextarea) {
          const mdImg = `![${data.filename}](${data.url})`;
          contentTextarea.value += `\n${mdImg}\n`;
          contentTextarea.dispatchEvent(new Event('input'));
        }
      } catch { alert('上传失败'); }
    }

    // 表单提交
    const form = /** @type {HTMLFormElement} */ (document.getElementById('editor-form'));
    if (form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const formData = new FormData(form);
        const id = formData.get('id');
        const data = {
          title: formData.get('title'),
          slug: formData.get('slug'),
          date: formData.get('date'),
          tags: String(formData.get('tags') || '').split(',').map((t) => t.trim()).filter(Boolean),
          excerpt: formData.get('excerpt'),
          content: formData.get('content'),
          published: true,
        };

        const method = id ? 'PUT' : 'POST';
        const url = id ? `/api/posts/${id}` : '/api/posts';

        try {
          const res = await fetch(url, {
            method,
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data),
          });
          if (res.ok) {
            window.location.href = '/admin';
          } else {
            const err = await res.json();
            alert(err.error || '保存失败');
          }
        } catch { alert('网络错误'); }
      });

      // 草稿按钮
      document.getElementById('save-draft-btn')?.addEventListener('click', async () => {
        const formData = new FormData(form);
        const id = formData.get('id');
        const data = {
          title: formData.get('title'),
          slug: formData.get('slug'),
          date: formData.get('date'),
          tags: String(formData.get('tags') || '').split(',').map((t) => t.trim()).filter(Boolean),
          excerpt: formData.get('excerpt'),
          content: formData.get('content'),
          published: false,
        };

        const method = id ? 'PUT' : 'POST';
        const url = id ? `/api/posts/${id}` : '/api/posts';

        try {
          const res = await fetch(url, { method, headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
          if (res.ok) {
            window.location.href = '/admin';
          } else {
            const err = await res.json();
            alert(err.error || '保存失败');
          }
        } catch { alert('网络错误'); }
      });
    }
  </script>
</AdminLayout>
