---
// src/pages/archive.astro — 归档页
import BlogLayout from '../layouts/BlogLayout.astro';
import GlassCard from '../components/glass/GlassCard.astro';
import GlassTag from '../components/glass/GlassTag.astro';
import { getAllPosts } from '../lib/posts';

const posts = await getAllPosts();

// 按年份分组
const byYear = new Map<string, typeof posts>();
posts.forEach((p) => {
  const year = p.date.slice(0, 4);
  if (!byYear.has(year)) byYear.set(year, []);
  byYear.get(year)!.push(p);
});
---

<BlogLayout title="归档">

  <div class="mt-12 mb-8">
    <h1 class="text-2xl font-bold" style="font-family: 'Microsoft YaHei', 'PingFang SC', sans-serif; font-weight: 900;">
      📅 文章归档
    </h1>
    <p class="text-sm text-[var(--text-muted)] mt-2">共 {posts.length} 篇文章</p>
  </div>

  <div class="space-y-12">
    {Array.from(byYear.entries()).sort(([a], [b]) => Number(b) - Number(a)).map(([year, yearPosts]) => (
      <section>
        <h2 class="text-3xl font-black text-gradient mb-6">{year}</h2>
        <div class="space-y-4">
          {yearPosts.map((post) => (
            <GlassCard hover={true} padding="medium">
              <div class="flex items-start justify-between gap-4 flex-wrap">
                <div class="flex-1 min-w-0">
                  <time class="text-xs text-[var(--text-muted)]" style="font-family: 'Microsoft YaHei', 'PingFang SC', sans-serif;">
                    {post.date}
                  </time>
                  <h3 class="text-lg font-bold mt-1 mb-2">
                    <a
                      href={`/posts/${post.slug}`}
                      class="text-[var(--text-primary)] no-underline transition-colors duration-250 hover:text-[var(--gold-light)]"
                    >
                      {post.title}
                    </a>
                  </h3>
                  <p class="text-sm text-[var(--text-secondary)]">{post.excerpt}</p>
                </div>
                <div class="flex flex-wrap gap-2">
                  {post.tags.map((tag) => (
                    <GlassTag href={`/tags/${tag}`}>{tag}</GlassTag>
                  ))}
                </div>
              </div>
            </GlassCard>
          ))}
        </div>
      </section>
    ))}
  </div>

  {posts.length === 0 && (
    <div class="glass p-12 text-center text-[var(--text-muted)]">还没有文章</div>
  )}
</BlogLayout>
