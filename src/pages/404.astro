---
// src/pages/404.astro — 404页面
import BlogLayout from '../layouts/BlogLayout.astro';
import GlassCard from '../components/glass/GlassCard.astro';
import GlassButton from '../components/glass/GlassButton.astro';
---

<BlogLayout title="页面不存在">

  <div class="mt-20 text-center">
    <GlassCard padding="large" class="max-w-[500px] mx-auto">
      <div class="text-6xl mb-6">🏹</div>
      <h1 class="text-2xl font-bold mb-4 text-gradient">箭未中的</h1>
      <p class="text-[var(--text-secondary)] mb-8">这页不存在，可能被删了，也可能从未有过。</p>
      <GlassButton variant="primary" href="/">← 回到首页</GlassButton>
    </GlassCard>
  </div>
</BlogLayout>
